{
  "name": "anchored-notes",
  "version": "0.1.1",
  "description": "Chrome extension to leave sticky notes anchored to pages, sites, tabs or globally",
  "type": "module",
  "private": true,
  "scripts": {
    "icons": "node mkicons.mjs",
    "locales": "node mklocales.mjs",
    "typecheck": "tsc --noEmit",
    "build": "node mkicons.mjs && node mklocales.mjs && node build.mjs",
    "test": "node --test",
    "package": "node package.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^25.9.3",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@milkdown/core": "^7.21.2",
    "@milkdown/plugin-clipboard": "^7.21.2",
    "@milkdown/plugin-listener": "^7.21.2",
    "@milkdown/plugin-slash": "^7.21.2",
    "@milkdown/preset-commonmark": "^7.21.2",
    "@milkdown/preset-gfm": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "@milkdown/utils": "^7.21.2"
  }
}
